# --- Database driver: local | dsql ---
DB_DRIVER=local

# Local Postgres (used when DB_DRIVER=local)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/pindrop

# Aurora DSQL (used when DB_DRIVER=dsql). Password is an IAM token minted at runtime
# via boto3 -- do NOT set a password here. Requires valid AWS credentials in the env
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN or an instance role).
DSQL_CLUSTER_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws
DSQL_USER=admin
DSQL_DATABASE=postgres
AWS_REGION=us-east-1

# --- Stripe: mock | test ---
# mock = no network, fake PaymentIntents (default; runs with no key).
# test = real Stripe test mode (free, no real charges). Needs sk_test_... below.
STRIPE_MODE=mock
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
